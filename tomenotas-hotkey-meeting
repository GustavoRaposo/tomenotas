#!/bin/bash
# tomenotas-hotkey-meeting
# Cliente D-Bus leve — alvo do atalho de gravar reunião (Super+[).
# Grava microfone + áudio do PC ao mesmo tempo. Só chama
# ToggleMeetingRecording() no daemon; se o daemon não estiver rodando, a
# chamada falha em silêncio e nada acontece (atalho só funciona com o app
# aberto).

gdbus call --session \
    --dest com.tomenotas.Daemon \
    --object-path /com/tomenotas/Daemon \
    --method com.tomenotas.Daemon.ToggleMeetingRecording \
    > /dev/null 2>&1

exit 0
