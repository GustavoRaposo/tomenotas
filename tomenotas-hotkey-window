#!/bin/bash
# tomenotas-hotkey-window
# Cliente D-Bus leve — alvo do atalho de teclado de listar (Super+L).
# Só chama ShowWindow() no daemon, que abre a janela de notas do Tomenotas;
# se o daemon não estiver rodando, a chamada falha em silêncio e nada
# acontece (atalho só funciona com o app aberto).

gdbus call --session \
    --dest com.tomenotas.Daemon \
    --object-path /com/tomenotas/Daemon \
    --method com.tomenotas.Daemon.ShowWindow \
    > /dev/null 2>&1

exit 0
