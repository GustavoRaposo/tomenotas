#!/bin/bash
# tomenotas-hotkey-critical
# Cliente D-Bus leve — alvo do atalho de gravar nota crítica (Super+I).
# Só chama ToggleCriticalRecording() no daemon; se o daemon não estiver
# rodando, a chamada falha em silêncio e nada acontece (comportamento
# desejado: atalho só funciona com o app aberto).

gdbus call --session \
    --dest com.tomenotas.Daemon \
    --object-path /com/tomenotas/Daemon \
    --method com.tomenotas.Daemon.ToggleCriticalRecording \
    > /dev/null 2>&1

exit 0
